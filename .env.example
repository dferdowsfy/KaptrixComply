# Kaptrix Delivery Platform — Environment Variables
# Copy to .env.local and fill in values. On Vercel, configure each of
# these in Project Settings → Environment Variables for every environment
# (Production / Preview / Development).
#
# Environment layout:
#   .env.development  — committed, non-secret dev defaults (APP_ENV=development)
#   .env.staging      — committed, non-secret staging defaults (APP_ENV=staging)
#   .env.production   — committed, non-secret prod defaults (APP_ENV=production)
#   .env.local        — gitignored, secrets for your local environment
#   Vercel env vars   — secrets per environment (Production / Preview / Development)

# ─── App ───────────────────────────────────────────────────────────────
# Which environment this build is running in.
# Values: development | staging | production
NEXT_PUBLIC_APP_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── Supabase ──────────────────────────────────────────────────────────
# Create 3 Supabase projects (kaptrix-dev, kaptrix-staging, kaptrix-prod)
# and fill in the corresponding values per Vercel environment.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# Optional newer publishable key (sb_publishable_...)
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
# Server-only — never expose to the browser
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_SECRET_KEY=

# ─── Groq (all AI functionality) ─────────────────────────────────────
# Obtain from https://console.groq.com/keys
GROQ_API_KEY=your-groq-api-key

# ─── OpenRouter (chat, scoring, reports, insight extraction) ─────────
# Obtain from https://openrouter.ai/keys
OPENROUTER_API_KEY=your-openrouter-api-key
# Optional: override the model used per task (defaults to openai/gpt-4o-mini)
# OPENROUTER_MODEL_CHAT=openai/gpt-4o-mini
# OPENROUTER_MODEL_SCORING=openai/gpt-4o-mini
# OPENROUTER_MODEL_REPORT=openai/gpt-4o-mini
# OPENROUTER_MODEL_EXTRACT=openai/gpt-4o-mini
# OPENROUTER_MODEL_DEFAULT=openai/gpt-4o-mini
# Set to "false" only if your chosen model has no ZDR-certified provider (not recommended)
# OPENROUTER_ZERO_RETENTION=true

# ─── Admin ─────────────────────────────────────────────────────────────
# Comma-separated emails that are always treated as admin regardless of DB role.
# Set a separate value per environment so staging has its own admin account.
ADMIN_EMAILS=you@example.com

# ─── Supabase project refs (used by scripts/db-push.sh only) ──────────
# Obtain from Supabase dashboard → Project Settings → General → Reference ID
# These are NOT secrets — safe to commit, but keep them in .env.local.
SUPABASE_PROJECT_REF_DEV=your-dev-project-ref
SUPABASE_PROJECT_REF_STAGING=your-staging-project-ref
SUPABASE_PROJECT_REF_PROD=your-prod-project-ref
# DB password (found in Supabase → Project Settings → Database → Password)
SUPABASE_DB_PASSWORD_DEV=your-dev-db-password
SUPABASE_DB_PASSWORD_STAGING=your-staging-db-password
SUPABASE_DB_PASSWORD_PROD=your-prod-db-password
